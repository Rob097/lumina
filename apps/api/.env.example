# @lumina/api — public widget API + merchant API + Inngest endpoint (server-only secrets).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# --- AI gateway (Vercel AI Gateway primary — D49; fal.ai kept dormant) ---
# Auth: an AI Gateway API key locally; on Vercel VERCEL_OIDC_TOKEN is used automatically (no key).
AI_GATEWAY_API_KEY=
# Set AI_PROVIDER=mock to run offline (local/e2e). Otherwise the gateway is used when creds exist.
AI_PROVIDER=
# Gateway model ids + our cost (cents) per tier (per architecture §7.2).
GATEWAY_MODEL_QUALITY=google/gemini-3-pro-image
GATEWAY_MODEL_FAST=google/gemini-3.1-flash-image-preview
GATEWAY_COST_QUALITY=13
GATEWAY_COST_FAST=6
# Cheap text+vision model for the coverage-quantity estimate (#7) — analysis, not image generation.
GATEWAY_MODEL_QUANTITY=google/gemini-2.5-flash
# Scene-analysis vision pass (Phase 2 / D64) — per-image facts (lighting/tilt/surfaces/scale). Best-effort;
# defaults to GATEWAY_MODEL_QUANTITY when unset. Uses the same AI_GATEWAY_API_KEY (no new credential).
SCENE_MODEL=google/gemini-2.5-flash
# Output resolution tier pinned per compose (1K|2K|4K). Aspect ratio is pinned per-request to the room.
GATEWAY_IMAGE_SIZE=2K
# Pixel-perfect compositing knobs (#AI-gen v2) — tune from real renders:
#  THRESHOLD: per-pixel colour-distance (0-255) above which a pixel counts as "changed".
#  FEATHER:   blur px softening the composite seam.
#  MIN/MAX_FRACTION: keep the full render (skip composite) when the changed area is below/above these.
CHANGE_MASK_THRESHOLD=28
CHANGE_MASK_FEATHER=6
CHANGE_MIN_FRACTION=0.002
CHANGE_MAX_FRACTION=0.6
# Room normalization (Phase 3 / D65): deskew the room using SceneAnalysis.tiltDegrees (clamped to
# ±DESKEW_MAX_DEGREES, cropped to the inscribed rectangle) + auto-level when the scene flags it dark.
# Code defaults work unset. Set AUTOLEVEL_ENABLED=false to disable the dark-photo auto-level.
DESKEW_MAX_DEGREES=8
AUTOLEVEL_ENABLED=true
# Product background removal (Phase 1 / D63): a clean product cutout cached on products.clean_image_key.
# Best-effort — unset ⇒ compose uses the raw product image. BG_REMOVAL_PROVIDER:
#   gateway   — RECOMMENDED, Vercel-consolidated: a generative cutout on the AI Gateway, reuses
#               AI_GATEWAY_API_KEY (no extra service/credential/billing). Re-renders the product (slightly
#               lower fidelity), fine as a reference since the compositor re-renders it anyway.
#   replicate — a true matting model (preserves the product pixels, higher fidelity) — needs a Replicate
#               token AND account billing credit (a no-credit account 402s → degrades to the raw image).
#   mock | none.
BG_REMOVAL_PROVIDER=
# --- gateway path ---
# Gateway image model for the cutout (default google/gemini-3-pro-image, i.e. GATEWAY_MODEL_QUALITY).
BG_REMOVAL_GATEWAY_MODEL=
# --- replicate path ---
REPLICATE_API_TOKEN=
# A non-official matting model MUST be version-pinned (owner/name:version or a bare 64-char version id).
# Verified — BiRefNet (input field `image`):
#   BG_REMOVAL_MODEL=men1scus/birefnet:f74986db0355b58403ed20963af156525e2891ea3c2d499bfbfb2a28cd87c5d7
BG_REMOVAL_MODEL=
BG_REMOVAL_INPUT_KEY=

# Generation workflow concurrency caps + abuse limits
GLOBAL_CONCURRENCY=20
MERCHANT_CONCURRENCY=3
RATE_PER_MINUTE=60
ANON_DAILY_CAP=5
MAX_UPLOAD_BYTES=10485760

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price ids per plan (drive plan + included-credit grants). EUR prices: Starter €149 / Growth €349 /
# Pro €699 / Enterprise from €1499. STRIPE_PRICE_SCALE is legacy (no longer sold; kept so old subs resolve).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=
# Free-trial length applied at checkout (days, no card required). Default 14; Relievum's campaign uses 30.
TRIAL_PERIOD_DAYS=14

RESEND_API_KEY=
RESEND_FROM="LUMINA <notifications@lumina.app>"
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=
# Axiom full ingest URL — e.g. an edge URL https://<region>.aws.edge.axiom.co/v1/ingest/<dataset>.
# Leave blank to use the standard https://api.axiom.co/v1/datasets/<AXIOM_DATASET>/ingest.
AXIOM_URL=

APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CDN_URL=http://localhost:5173
