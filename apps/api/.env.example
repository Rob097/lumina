# @lumina/api — public widget API + merchant API + Inngest endpoint (server-only secrets).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

FAL_KEY=
# AI models + costs (per architecture §7.2). Set AI_PROVIDER=mock to run offline (local/e2e).
AI_PROVIDER=
FAL_MODEL_QUALITY=fal-ai/nano-banana-pro/edit
FAL_MODEL_FAST=fal-ai/flux-2/edit
FAL_COST_QUALITY=13
FAL_COST_FAST=6

# Generation workflow concurrency caps + abuse limits
GLOBAL_CONCURRENCY=20
MERCHANT_CONCURRENCY=3
RATE_PER_MINUTE=60
ANON_DAILY_CAP=5
MAX_UPLOAD_BYTES=10485760

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price ids per plan (drive plan + included-credit grants)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=

RESEND_API_KEY=
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CDN_URL=http://localhost:5173
