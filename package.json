{
  "name": "lumina",
  "private": true,
  "version": "0.0.0",
  "description": "LUMINA — AI Visual Commerce SaaS (\"Try in your room\")",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm -F @lumina/db db:generate",
    "db:migrate": "pnpm -F @lumina/db db:migrate",
    "db:seed": "pnpm -F @lumina/db db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
