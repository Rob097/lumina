# =============================================================================
# LUMINA — environment variables (aggregate reference; see Appendix A of the spec)
# Copy to `.env` and fill in. NEVER commit real secrets. Per-app `.env.example` files
# list the subset each app needs. Secrets are server-only — the widget only ever sees
# PUBLIC_* values, a site_key, presigned URLs, and a generationId.
# =============================================================================

# --- Database (Drizzle migrations/seed + API) ---
# Local dev: a Postgres connection string. With Supabase, use the pooled connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# --- Supabase (Auth / Realtime / Storage glue) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate limit / idempotency / result cache / anon caps) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (image storage, S3 API) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# --- AI gateway (fal.ai primary; Vertex optional fallback) ---
FAL_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=

# --- Inngest (durable AI workflow) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Observability ---
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

# --- URLs ---
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CDN_URL=http://localhost:5173

# --- Tests (optional): point db integration tests at an existing Postgres instead of
#     spinning up a Testcontainers Postgres (used in CI). ---
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumina_test
