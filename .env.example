# =============================================================================
# LUMINA — environment variables (aggregate reference; see Appendix A of the spec)
# Copy to `.env` and fill in. NEVER commit real secrets. Per-app `.env.example` files
# list the subset each app needs. Secrets are server-only — the widget only ever sees
# PUBLIC_* values, a site_key, presigned URLs, and a generationId.
# =============================================================================

# --- Database (Drizzle migrations/seed + API) ---
# Local dev: a Postgres connection string. With Supabase, use the pooled connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# --- Supabase (Auth / Realtime / Storage glue) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate limit / idempotency / result cache / anon caps) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (image storage, S3 API) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=

# --- AI gateway (Vercel AI Gateway primary — D49; fal.ai/Vertex dormant) ---
# Local: an AI Gateway API key. On Vercel: VERCEL_OIDC_TOKEN is used automatically (no key needed).
AI_GATEWAY_API_KEY=
GATEWAY_MODEL_QUALITY=google/gemini-3-pro-image
GATEWAY_MODEL_FAST=google/gemini-3.1-flash-image-preview
GATEWAY_COST_QUALITY=13
GATEWAY_COST_FAST=6
# Cheap text+vision model for the coverage-quantity estimate (#7) — analysis, not image generation.
GATEWAY_MODEL_QUANTITY=google/gemini-2.5-flash
# Planner pass (Generation Engine v3 §4.1 / D68) — one reasoning call over BOTH images + product metadata
# returning the operation (surface_covering | object_replacement | object_placement) + per-image facts
# (lighting/tilt/surfaces/scale). Replaces the former scene-analysis pass (one call, not two). Best-effort;
# defaults to GATEWAY_MODEL_QUANTITY when unset. Reuses AI_GATEWAY_API_KEY (no new credential/platform).
# `SCENE_MODEL` is still honoured as a legacy alias.
PLANNER_MODEL=google/gemini-2.5-flash
# Output resolution tier pinned per compose (1K|2K|4K); aspect ratio is pinned per-request to the room.
GATEWAY_IMAGE_SIZE=2K
# Pixel-perfect compositing knobs (#AI-gen v2): change-detection threshold (0-255), feather px, and the
# min/max changed-fraction outside which we keep the full render. Tune from real renders.
CHANGE_MASK_THRESHOLD=28
CHANGE_MASK_FEATHER=6
CHANGE_MIN_FRACTION=0.002
CHANGE_MAX_FRACTION=0.6
# Room normalization (Phase 3 / D65): deskew using SceneAnalysis.tiltDegrees (clamped to ±DESKEW_MAX_DEGREES,
# cropped to the inscribed rectangle) + conditional auto-level when the scene flags the photo dark. Code
# defaults work unset; AUTOLEVEL_ENABLED=false disables the dark-photo auto-level.
DESKEW_MAX_DEGREES=8
AUTOLEVEL_ENABLED=true
# Product background removal (Phase 1 / D63): a clean product cutout cached on products.clean_image_key.
# Best-effort — unset ⇒ compose uses the raw product image. BG_REMOVAL_PROVIDER:
#   gateway   — RECOMMENDED, Vercel-only: a generative cutout on the AI Gateway, reuses AI_GATEWAY_API_KEY
#               (no extra service/billing). Re-renders the product (slightly lower fidelity) but it's only a
#               reference (the compositor re-renders it anyway).
#   replicate — true matting (preserves product pixels, higher fidelity) — needs a Replicate token + credit.
#   mock | none.
BG_REMOVAL_PROVIDER=
# gateway path: image model for the cutout (default google/gemini-3-pro-image).
BG_REMOVAL_GATEWAY_MODEL=
# replicate path: token + a version-pinned matting model (owner/name:version or a bare 64-char version id).
# Verified — BiRefNet (input field `image`); needs Replicate billing credit or every cutout 402s.
#   BG_REMOVAL_MODEL=men1scus/birefnet:f74986db0355b58403ed20963af156525e2891ea3c2d499bfbfb2a28cd87c5d7
REPLICATE_API_TOKEN=
BG_REMOVAL_MODEL=
BG_REMOVAL_INPUT_KEY=
# Dormant providers (swap back via packages/ai/factory.ts):
# VERTEX_PROJECT=
# VERTEX_LOCATION=

# --- Inngest (durable AI workflow) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=

# --- Email (Resend) ---
# Notifications (and later, invites) send via Resend when RESEND_API_KEY is set; otherwise email is
# skipped and in-app notifications still work. RESEND_FROM must be a verified sender/domain in Resend.
RESEND_API_KEY=
RESEND_FROM="LUMINA <notifications@lumina.app>"

# --- Observability ---
SENTRY_DSN=
SENTRY_RELEASE=
AXIOM_TOKEN=
AXIOM_DATASET=
# Axiom full ingest URL — e.g. an edge URL https://<region>.aws.edge.axiom.co/v1/ingest/<dataset>.
# Leave blank to use the standard https://api.axiom.co/v1/datasets/<AXIOM_DATASET>/ingest.
AXIOM_URL=

# --- Hardening / abuse / retention / tuning (M5) ---
# Per-key request rate (sliding window / minute) + per-anonymous-visitor daily generation cap.
RATE_PER_MINUTE=60
ANON_DAILY_CAP=5
# Inngest concurrency caps (global + per-merchant) protecting provider budget/rate limits.
GLOBAL_CONCURRENCY=20
MERCHANT_CONCURRENCY=3
# Data retention: purge generations + their room/result objects older than N days (ledger preserved).
RETENTION_DAYS=90
RETENTION_CRON=0 3 * * *

# --- URLs ---
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CDN_URL=http://localhost:5173

# --- Tests (optional): point db integration tests at an existing Postgres instead of
#     spinning up a Testcontainers Postgres (used in CI). ---
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumina_test
